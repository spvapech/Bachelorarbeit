# Supabase Configuration
# Copy this file to .env and fill in your actual Supabase credentials

# Your Supabase project URL (found in Project Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase service_role key — used by the backend for write operations (bypasses RLS).
# Found in Project Settings > API > service_role (secret). Keep this out of version control.
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-here

# Supabase anon/public key — optional fallback for local dev without a service role key.
SUPABASE_KEY=your-supabase-anon-key-here
